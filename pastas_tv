def mesclar_listas(lista, nome_saida="lista_completa.m3u"):
    conteudo_final = ["#EXTM3U\n"] # Inicia com o cabeçalho padrão
    
    print(f"--- A iniciar a união das listas ---")
    
    for item in lista:
        nome = item["nome"].strip()
        url = item["url"]
        
        try:
            print(f"A processar: {nome}...")
            resposta = requests.get(url, timeout=15)
            
            if resposta.status_code == 200:
                linhas = resposta.text.splitlines()
                
                # Adiciona um comentário para separar as categorias no ficheiro
                conteudo_final.append(f"\n# --- CATEGORIA: {nome} ---\n")
                
                for linha in linhas:
                    # Ignora cabeçalhos repetidos das listas individuais
                    if linha.strip() == "#EXTM3U" or not linha.strip():
                        continue
                    conteudo_final.append(linha + "\n")
                
                print(f"✅ {nome} adicionado.")
            else:
                print(f"⚠️ Erro no link {nome} (Status: {resposta.status_code})")
                
        except Exception as e:
            print(f"❌ Falha ao descarregar {nome}: {e}")

    # Grava tudo no ficheiro final
    with open(nome_saida, "w", encoding="utf-8") as f:
        f.writelines(conteudo_final)
    
    print(f"\n✨ Concluído! O ficheiro '{nome_saida}' foi criado com sucesso.")

if __name__ == "__main__":
    mesclar_listas(ESTRUTURA)
